# Gemini API key (chat model + embeddings)
GOOGLE_API_KEY=

# HuggingFace token (used by local R&D notebooks/embeddings, not required by app.py)
HF_TOKEN=

# Supabase Postgres connection string (Session pooler or direct connection),
# e.g. postgresql://postgres:[password]@[host]:5432/postgres
SUPABASE_DB_URL=

# Basic auth for the Gradio app (technician login)
APP_USERNAME=
APP_PASSWORD=
